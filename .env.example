# ============================================================
# Email Lead Capture Pipeline — Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- REQUIRED: API Keys ---
# Get from console.anthropic.com > API Keys
CLAUDE_API_KEY=your_claude_api_key_here

# Get from GHL > Settings > Integrations > Private Integrations
GHL_API_KEY=your_ghl_api_key_here

# Get from GHL > Settings > Business Profile (or from the URL)
GHL_LOCATION_ID=your_ghl_location_id_here

# --- REQUIRED: Email Settings ---
# Comma-separated list of allowed sender email addresses
ALLOWED_SENDERS=fund19@protonmail.com

# GHL custom field ID for the Source Documents FILE_UPLOAD field
# Run: python scripts/get_field_ids.py to find this
SOURCE_DOCUMENTS_FIELD_ID=your_ghl_file_upload_custom_field_id

# --- OPTIONAL: Security ---
# SendGrid signs webhooks with this key (optional but recommended for production)
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# Admin API key for debug/cleanup endpoints
ADMIN_API_KEY=

# --- OPTIONAL: Claude AI Settings ---
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4000
CLAUDE_TIMEOUT=60

# --- OPTIONAL: Processing Settings ---
# Minimum confidence (0.0-1.0) to accept an extraction. Default 0.25.
MIN_CONFIDENCE_THRESHOLD=0.25

# Hours to remember processed emails (dedup window). Default 24.
IMAGE_FINGERPRINT_TTL_HOURS=24

# --- OPTIONAL: Application Settings ---
LOG_LEVEL=INFO
ENV=development
DEBUG=false

# --- OPTIONAL: Database ---
# SQLite works out of the box. For persistent storage, use PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./email_ghl.db

# --- OPTIONAL: Monitoring ---
# Redis (not required)
REDIS_URL=

# Sentry error tracking (not required)
SENTRY_DSN=
