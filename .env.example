# ============================================================
# Email Lead Pipeline — Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- REQUIRED: API Keys ---
CLAUDE_API_KEY=your_claude_api_key_here
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# --- REQUIRED: IMAP Settings (email monitoring) ---
# Get these from your email provider's settings
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_EMAIL=uwteam@onixcap.net
IMAP_PASSWORD=your_email_password_here

# --- REQUIRED: GHL Custom Field ---
# GHL custom field ID for the Source Documents FILE_UPLOAD field
# Run: python scripts/get_field_ids.py to find this
SOURCE_DOCUMENTS_FIELD_ID=your_ghl_file_upload_custom_field_id

# --- OPTIONAL: SMTP Settings (failure notifications) ---
# Usually same host/credentials as IMAP
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587

# Email to receive failure notifications (defaults to IMAP_EMAIL)
NOTIFICATION_EMAIL=

# --- OPTIONAL: Admin Access ---
ADMIN_API_KEY=

# --- OPTIONAL: Claude AI Settings ---
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4000
CLAUDE_TIMEOUT=60

# --- OPTIONAL: Processing Settings ---
MIN_CONFIDENCE_THRESHOLD=0.25
IMAGE_FINGERPRINT_TTL_HOURS=24

# --- OPTIONAL: Application Settings ---
LOG_LEVEL=INFO
ENV=development
DEBUG=false

# --- OPTIONAL: Database ---
DATABASE_URL=sqlite:///./email_ghl.db

# --- OPTIONAL: Monitoring ---
REDIS_URL=
SENTRY_DSN=
